{
  "version": 2,
  "builds": [
    {
      "src": "package.json",
      "use": "@vercel/next"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "https://starktrade-ai-backend.railway.app/api/$1"
    },
    {
      "src": "/(.*)",
      "dest": "/$1"
    }
  ],
  "env": {
    "NEXT_PUBLIC_API_URL": "https://starktrade-ai-backend.railway.app",
    "NEXT_PUBLIC_WS_URL": "wss://starktrade-ai-backend.railway.app/api/v1/ws"
  }
}
