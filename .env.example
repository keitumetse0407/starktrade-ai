# ============================================================
# StarkTrade AI — Environment Variables
# ============================================================
# Copy this file to .env and fill in your values
# cp .env.example .env

# ============================================================
# REQUIRED
# ============================================================

# Generate with: openssl rand -hex 32
SECRET_KEY=change-me-generate-with-openssl-rand-hex-32

# OpenAI API key — for AI agent intelligence
# Get at: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-openai-key-here

# ============================================================
# DATABASE (Docker defaults work out of the box)
# ============================================================

DATABASE_URL=postgresql+asyncpg://starktrade:starktrade@localhost:5432/starktrade
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# ============================================================
# APP SETTINGS
# ============================================================

APP_NAME=StarkTrade AI
APP_VERSION=1.0.0
DEBUG=true
ENVIRONMENT=development

# ============================================================
# MARKET DATA (Optional — paper trading works without these)
# ============================================================

# Alpha Vantage — free tier: 500 calls/day
# Get at: https://www.alphavantage.co/support/#api-key
ALPHA_VANTAGE_API_KEY=

# News API — free tier: 100 requests/day
# Get at: https://newsapi.org/register
NEWS_API_KEY=

# ============================================================
# BROKER APIs (Optional — connect when ready for live trading)
# ============================================================

# Alpaca — commission-free stock trading
# Get at: https://app.alpaca.markets/paper/dashboard/overview
ALPACA_API_KEY=
ALPACA_SECRET_KEY=
ALPACA_BASE_URL=https://paper-api.alpaca.markets

# ============================================================
# VECTOR STORE
# ============================================================

QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=

# ============================================================
# PAYMENTS (Paystack - African payment gateway)
# ============================================================

# Get at: https://dashboard.paystack.com/#/settings/developer
PAYSTACK_SECRET_KEY=sk_test_xxxxx
PAYSTACK_PUBLIC_KEY=pk_test_xxxxx

# ============================================================
# BROKER (Alpaca - Free paper trading)
# ============================================================

# Get at: https://app.alpaca.markets/paper/dashboard/overview
ALPACA_API_KEY=
ALPACA_SECRET_KEY=
ALPACA_BASE_URL=https://paper-api.alpaca.markets

# ============================================================
# MONITORING
# ============================================================

# Sentry Error Tracking
# Get at: https://sentry.io (free tier: 5K errors/month)
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=

# Grafana
GF_SECURITY_ADMIN_PASSWORD=admin

# ============================================================
# AD REVENUE (Optional — for AdSense monetization)
# ============================================================

# Google AdSense Publisher ID (ca-pub-XXXXXXXXXXXXXXXX)
ADSENSE_CLIENT_ID=

# ============================================================
# NOTIFICATIONS (Optional)
# ============================================================

# WhatsApp Business API
WHATSAPP_API_URL=
WHATSAPP_API_TOKEN=

# Email notifications (SMTP)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
